# Copy to .env (git-ignored) and fill in. bin/geo and every make target
# source this file automatically. chmod 600 .env after filling it in.

# Telegram alerts (required for any run you care about)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic classifier (required unless classifier.provider is rule_based)
ANTHROPIC_API_KEY=

# Polymarket CLOB credentials (required only for --live execution;
# paper/alert_only runs never need these)
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_FUNDER_ADDRESS=
