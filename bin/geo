#!/usr/bin/env bash
# Single entry point for every geopolitics command. Sources .env (secrets),
# uses the repo venv, and passes everything through to the CLI:
#   bin/geo fleet-status --config configs/geopolitics/discovery.yaml
#   bin/geo run-fleet --config ... --live
#   bin/geo replay --config <bot.yaml> --articles logs/binary_articles.jsonl
# Most day-to-day invocations have `make` shortcuts -- see `make help`.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if [ -f .env ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env
    set +a
fi

PYTHON="$REPO_ROOT/.venv/bin/python"
if [ ! -x "$PYTHON" ]; then
    echo "error: no venv at .venv/ -- run 'make setup' first" >&2
    exit 1
fi

exec "$PYTHON" -m polybot.geopolitics "$@"
