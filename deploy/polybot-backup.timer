# Hourly snapshot of the financial record. Install alongside the service:
#   sudo cp deploy/polybot-backup.{service,timer} /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now polybot-backup.timer
[Unit]
Description=Hourly polybot data snapshot

[Timer]
OnCalendar=hourly
Persistent=true

[Install]
WantedBy=timers.target
